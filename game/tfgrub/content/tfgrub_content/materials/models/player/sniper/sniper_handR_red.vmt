"VertexLitGeneric"
{
	"$basetexture" "models\player\sniper\sniper_handR_red"
	// "$bumpmap" "models\player\sniper\sniper_handR_red_normal"

	"$phong" 				"1"
	"$phongexponent"		"10"
	"$phongboost" 			".15"	
	"$lightwarptexture" 	"models/lightwarps/hand_lightwarp"
	"$phongfresnelranges"	"[.3 1 8]"
	"$halflambert" 			"0"

	// Rim lighting parameters
	"$rimlight" 			"1"			// To enable rim lighting (requires phong)
	"$rimlightexponent" 	"4"			// Exponent for phong component of rim lighting		
	"$rimlightboost" 		".3"		// Boost for ambient cube component of rim lighting
	"$rimmask" 				"1"			// Mask the rim light with alpha channel of specular exponent map
	
	// Cloaking
	"$cloakPassEnabled"		"1"
	"Proxies"
	{
		"spy_invis" //wmodel and team color cloak support
		{
		}
		"invis" //vmodel cloak support
		{
		}
	}
	
}