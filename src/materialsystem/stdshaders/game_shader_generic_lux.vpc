				$File "$STDSHADERS/lux_spritecard_spline_vs30.fxc"
				$File "$STDSHADERS/lux_spritecard_vs30.fxc"
				$File "$STDSHADERS/lux_sprite_ps30.fxc"
				$File "$STDSHADERS/lux_sprite_vs30.fxc"
				$File "$STDSHADERS/lux_teeth_ps30.fxc"
				$File "$STDSHADERS/lux_teeth_vs30.fxc"
				$File "$STDSHADERS/lux_triplanar_brush_flashlight_ps30.fxc"
				$File "$STDSHADERS/lux_triplanar_brush_ps30.fxc"
				$File "$STDSHADERS/lux_triplanar_displacement_flashlight_ps30.fxc"
				$File "$STDSHADERS/lux_triplanar_displacement_ps30.fxc"
				$File "$STDSHADERS/lux_triplanar_model_flashlight_ps30.fxc"
				$File "$STDSHADERS/lux_triplanar_model_ps30.fxc"
				$File "$STDSHADERS/lux_unlitgeneric_ps30.fxc"
				$File "$STDSHADERS/lux_vertexlitgeneric_bump_ps30.fxc"
				$File "$STDSHADERS/lux_vertexlitgeneric_flashlight_ps30.fxc"
				$File "$STDSHADERS/lux_vertexlitgeneric_phong_ps30.fxc"
				$File "$STDSHADERS/lux_vertexlitgeneric_simple_ps30.fxc"
				$File "$STDSHADERS/lux_water_cheap_ps30.fxc"
				$File "$STDSHADERS/lux_water_expensive_ps30.fxc"
				$File "$STDSHADERS/lux_water_vs30.fxc"
				$File "$STDSHADERS/lux_worldvertextransition_bump_ps30.fxc"
				$File "$STDSHADERS/lux_worldvertextransition_flashlight_ps30.fxc"
				$File "$STDSHADERS/lux_worldvertextransition_phong_ps30.fxc"
				$File "$STDSHADERS/lux_worldvertextransition_simple_ps30.fxc"
		//		$File "$STDSHADERS/
			}
		}

		$Folder	"Shaders (C++)"
		{
			$Folder "Triplanar"
			{
				$File "$SHADERSOURCE/triplanar/Triplanar.h"
				$File "$SHADERSOURCE/triplanar/Triplanar_model.cpp"
				$File "$SHADERSOURCE/triplanar/Triplanar_brush.cpp"
				$File "$SHADERSOURCE/triplanar/Triplanar_displacement.cpp"
			}

			$Folder "DistanceAlpha"
			{
				$File "$SHADERSOURCE/distancealpha/DistanceAlpha_Brush.cpp"
				$File "$SHADERSOURCE/distancealpha/DistanceAlpha_Model.cpp"
				$File "$SHADERSOURCE/distancealpha/DistanceAlpha_Unlit.cpp"
			}
			
			// Additional Renderpasses
			$Folder "Additional Renderpasses"
			{
				$File "$SHADERSOURCE/renderpasses/EmissiveBlend.cpp"
				$File "$SHADERSOURCE/renderpasses/EmissiveBlend.h"
				$File "$SHADERSOURCE/renderpasses/Cloak.cpp"
				$File "$SHADERSOURCE/renderpasses/Cloak.h"
				$File "$SHADERSOURCE/renderpasses/FleshInterior.cpp"
				$File "$SHADERSOURCE/renderpasses/FleshInterior.h"
				$File "$SHADERSOURCE/renderpasses/MeshOutline.cpp"
				$File "$SHADERSOURCE/renderpasses/MeshOutline.h"
				$File "$SHADERSOURCE/renderpasses/SheenPass.cpp"
				$File "$SHADERSOURCE/renderpasses/SheenPass.h"
			}
			
			$Folder "Recreated Shaders"
			{
				$File "$SHADERSOURCE/recreations/Black.cpp"
				$File "$SHADERSOURCE/recreations/Infected.cpp"
			}

			$File "$SHADERSOURCE/LightmappedGeneric.cpp"
			$File "$SHADERSOURCE/LightmappedGeneric_Decal.cpp"
			$File "$SHADERSOURCE/LightmappedReflective.cpp"
			$File "$SHADERSOURCE/Teeth.cpp"
			$File "$SHADERSOURCE/UnlitGeneric.cpp"
			$File "$SHADERSOURCE/UnlitTwoTexture.cpp"
			$File "$SHADERSOURCE/VertexLitGeneric.cpp"
			$File "$SHADERSOURCE/WorldVertexTransition.cpp"
			$File "$SHADERSOURCE/DecalModulate.cpp"
			$File "$SHADERSOURCE/Cloud.cpp"
			$File "$SHADERSOURCE/Water.cpp"
			$File "$SHADERSOURCE/Refract.cpp"
			$File "$SHADERSOURCE/EyeRefract.cpp"
			$File "$SHADERSOURCE/Modulate.cpp"
			$File "$SHADERSOURCE/Cable.cpp"
			$File "$SHADERSOURCE/Sky_Complex.cpp"
			$File "$SHADERSOURCE/Sky_Equirectangular.cpp"
			$File "$SHADERSOURCE/Sky_Simple.cpp"
			$File "$SHADERSOURCE/Sprite.cpp"
			$File "$SHADERSOURCE/Spritecard.cpp"
			$File "$SHADERSOURCE/ShatteredGlass.cpp"
			$File "$SHADERSOURCE/Core.cpp"
			$File "$SHADERSOURCE/CustomShader.cpp"
			$File "$SHADERSOURCE/Bloom.cpp"
			$File "$SHADERSOURCE/BlurFilters.cpp"
			$File "$SHADERSOURCE/Screenspace_General.cpp"
			$File "$SHADERSOURCE/EnginePost.cpp"
			$File "$SHADERSOURCE/DebugStubs.cpp"
			$File "$SHADERSOURCE/DebugTextureView.cpp"
			$File "$SHADERSOURCE/DebugLuxels.cpp"
		}
	}

	$Folder	"Header Files"
	{
		$File	"BaseVSShader.h"
		$File	"lux_common_defines.h"
		$File	"lux_registermap_cpp.h"
		$File	"cpp_convars.h"
		$File	"cpp_floatx.h"
		$File	"cpp_lux_commandbuilder.h"
		$File	"cpp_lux_shared.h"

		// ShaderLib Headers!
		// IMPORTANT: Has to be here so it overrides public/ versions of the same headers!
		$File	"$SHADERLIB\shaderdll_global.h"
		$File	"$SHADERLIB\shaderlib_cvar.h"
		$File	"$SHADERLIB\BaseShader.h"
		$File	"$SHADERLIB\cshader.h"
		$File	"$SHADERLIB\ShaderDLL.h"
		
		// Supposed to be in MaterialSystem/ but moved to Shaderlib/ as its part of the BaseShader System.
		$File	"$SHADERLIB\ishadersystem.h"
	}

	// Modified SDK2007 ShaderLib
	// Uses some References from Alien Swarm for fixing up missing things
	$Folder "BaseShader"
	{
		// Base Shaderlib
		$File	"$SHADERLIB\baseshader.cpp"
		$File	"$SHADERLIB\shaderdll.cpp"
		$File	"$SHADERLIB\shaderlib_cvar.cpp"

		// LUX Additions
		$File	"$SHADERLIB\ProxyShaderAPI.cpp"
		$File	"$SHADERLIB\ProxyShaderAPI.h"
		$File	"$SHADERLIB\ProxyShaderShadow.cpp"
		$File	"$SHADERLIB\ProxyShaderShadow.h"
		$File	"$SHADERLIB\ShaderSpew.cpp"
		$File	"$SHADERLIB\ShaderSpew.h"
		$File	"$SHADERLIB\VCSHotReload.cpp"
		$File	"$SHADERLIB\VCSHotReload.h"
	}

	$Folder "Link Libraries"
	{
        $Lib	mathlib
//      $Lib	shaderlib
		$Lib	tier2
    }
}