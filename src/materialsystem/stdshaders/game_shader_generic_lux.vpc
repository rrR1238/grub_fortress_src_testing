				$File "$STDSHADERS/lux_cable_spline_vs30.fxc"
				$File "$STDSHADERS/lux_cable_vs30.fxc"
				$File "$STDSHADERS/lux_cloak_ps30.fxc"
				$File "$STDSHADERS/lux_cloak_vs30.fxc"
				$File "$STDSHADERS/lux_cloud_ps30.fxc"
				$File "$STDSHADERS/lux_cloud_vs30.fxc"
				$File "$STDSHADERS/lux_combinetextures_ps30.fxc"
				$File "$STDSHADERS/lux_combinetextures_vs30.fxc"
				$File "$STDSHADERS/lux_core_ps30.fxc"
				$File "$STDSHADERS/lux_core_vs30.fxc"
				$File "$STDSHADERS/lux_custom_brush_vs30.fxc"
				$File "$STDSHADERS/lux_custom_model_vs30.fxc"
				$File "$STDSHADERS/lux_custom_particle_ps30.fxc"
				$File "$STDSHADERS/lux_custom_particle_vs30.fxc"
				$File "$STDSHADERS/lux_custom_projtex_ps30.fxc"
				$File "$STDSHADERS/lux_custom_ps30.fxc"
				$File "$STDSHADERS/lux_debug_luxels_ps30.fxc"
				$File "$STDSHADERS/lux_debug_luxels_vs30.fxc"
				$File "$STDSHADERS/lux_debug_textureview_ps30.fxc"
				$File "$STDSHADERS/lux_debug_textureview_vs30.fxc"
				$File "$STDSHADERS/lux_decalmodulate_ps30.fxc"
				$File "$STDSHADERS/lux_depthoffield_ps30.fxc"
				$File "$STDSHADERS/lux_depthtodestalpha_ps30.fxc"
				$File "$STDSHADERS/lux_displacement_vs30.fxc"
				$File "$STDSHADERS/lux_distancealpha_ps30.fxc"
				$File "$STDSHADERS/lux_emissive_ps30.fxc"
				$File "$STDSHADERS/lux_emissive_vs30.fxc"
				$File "$STDSHADERS/lux_engine_post_ps30.fxc"
				$File "$STDSHADERS/lux_eyes_ps30.fxc"
				$File "$STDSHADERS/lux_eyes_vs30.fxc"
				$File "$STDSHADERS/lux_infected_ps30.fxc"
				$File "$STDSHADERS/lux_infected_vs30.fxc"
				$File "$STDSHADERS/lux_lightmappedgeneric_bump_ps30.fxc"
				$File "$STDSHADERS/lux_lightmappedgeneric_decal_ps30.fxc"
				$File "$STDSHADERS/lux_lightmappedgeneric_flashlight_ps30.fxc"
				$File "$STDSHADERS/lux_lightmappedgeneric_phong_ps30.fxc"
				$File "$STDSHADERS/lux_lightmappedgeneric_simple_ps30.fxc"
				$File "$STDSHADERS/lux_lightmappedreflective_ps30.fxc"
				$File "$STDSHADERS/lux_lightmappedreflective_vs30.fxc"
				$File "$STDSHADERS/lux_meshoutline_ps30.fxc"
				$File "$STDSHADERS/lux_meshoutline_vs30.fxc"
				$File "$STDSHADERS/lux_modelshadertest_ps30.fxc"
				$File "$STDSHADERS/lux_modelshadertest_vs30.fxc"
				$File "$STDSHADERS/lux_model_bump_vs30.fxc"
				$File "$STDSHADERS/lux_model_simplified_vs30.fxc"
