//-----------------------------------------------------------------------------
//	game_shader_generic_example_base.vpc
//
//	Project Script for mods to use an an example of how to override shaders
//-----------------------------------------------------------------------------

$Macro OUTBINDIR	"$SRCDIR\..\game\$GAMENAME\bin"
$Macro SHADERSOURCE "$SRCDIR\materialsystem\stdshaders\shadersource"
$Macro STDSHADERS	"$SRCDIR\materialsystem\stdshaders"
$Macro SHADERLIB	"$SRCDIR\materialsystem\shaderlib"

$Include "$SRCDIR\vpc_scripts\source_dll_base.vpc"

$Configuration	"Debug"
{
	$General
	{
		$OutputDirectory		"Debug_dx9_$GAMENAME"			[$WINDOWS]
		$IntermediateDirectory	"Debug_dx9_$GAMENAME"			[$WINDOWS]
	}
}

$Configuration	"Release"
{
	$General
	{
		$OutputDirectory		"Release_dx9_$GAMENAME"		[$WINDOWS]
		$IntermediateDirectory	"Release_dx9_$GAMENAME"		[$WINDOWS]
	}
}

// Common Configuration
$Configuration
{
	$Compiler
	{
		$AdditionalIncludeDirectories	"$BASE;include;"
		$PreprocessorDefinitions		"$BASE;STDSHADER_DX9_DLL_EXPORT;FAST_MATERIALVAR_ACCESS;GAME_SHADER_DLL"
		$PreprocessorDefinitions		"$BASE;USE_ACTUAL_DX" [$WINDOWS && !$GL]
	}

	$Linker
	{
		$AdditionalDependencies			"$BASE version.lib winmm.lib"	[$WINDOWS]
	}
}

$Project
{
	$Folder	"Source Files"
	{
		$File	"BaseVSShader.cpp"
		$File	"cpp_convars.cpp"
		$File	"cpp_floatx.cpp"

		$Folder "Shaders (HLSL)"
		{
			$Folder "LUX (HLSL)"
			{
				// Constant Register Maps
				$File "$STDSHADERS/lux_registermap_hlsl.h"
				$File "$STDSHADERS/lux_registermap_ps.h"
				$File "$STDSHADERS/lux_registermap_vs.h"

				// .h Include Files
				$File "$STDSHADERS/lux_common_bicubic.h"
				$File "$STDSHADERS/lux_common_constants.h"
				$File "$STDSHADERS/lux_common_defines.h"
				$File "$STDSHADERS/lux_common_depth.h"
				$File "$STDSHADERS/lux_common_detailtexture.h"
				$File "$STDSHADERS/lux_common_envmap.h"
				$File "$STDSHADERS/lux_common_flashlight.h"
				$File "$STDSHADERS/lux_common_fxc.h"
				$File "$STDSHADERS/lux_common_intro.h"
				$File "$STDSHADERS/lux_common_lighting.h"
				$File "$STDSHADERS/lux_common_lightmapped.h"
				$File "$STDSHADERS/lux_common_lightwarp.h"
				$File "$STDSHADERS/lux_common_normalmap.h"
				$File "$STDSHADERS/lux_common_phong.h"
				$File "$STDSHADERS/lux_common_phong_data.h"
				$File "$STDSHADERS/lux_common_phong_flashlight.h"
				$File "$STDSHADERS/lux_common_pragmas.h"
				$File "$STDSHADERS/lux_common_ps_fxc.h"
				$File "$STDSHADERS/lux_common_selfillum.h"
				$File "$STDSHADERS/lux_common_spline.h"
				$File "$STDSHADERS/lux_common_triplanar.h"
				$File "$STDSHADERS/lux_common_vs_brush.h"
				$File "$STDSHADERS/lux_common_vs_fxc.h"
				$File "$STDSHADERS/lux_common_vs_model.h"
				$File "$STDSHADERS/lux_common_vs_sway.h"

				// Shader-Specific Headers
				$File "$STDSHADERS/lux_custom_common_ps.h"
				$File "$STDSHADERS/lux_custom_common_vs.h"
				$File "$STDSHADERS/lux_worldvertextransition.h"
				$File "$STDSHADERS/lux_triplanar_displacement.h"
				$File "$STDSHADERS/lux_infected_ps30.h"

				// Register Maps
				$File "$STDSHADERS/lux_infected_registermap.h"
				$File "$STDSHADERS/lux_unlitgeneric_registermap.h"			

				// .fxc Files
				$File "$STDSHADERS/lux_black_ps30.fxc"
				$File "$STDSHADERS/lux_bloom_ps30.fxc"
				$File "$STDSHADERS/lux_blurfilters_ps30.fxc"
				$File "$STDSHADERS/lux_blurfilters_vs30.fxc"
